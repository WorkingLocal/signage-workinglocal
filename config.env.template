# Xibo CMS configuratie — Working Local
# Kopieer dit bestand naar config.env en vul de waarden in.
# config.env wordt NOOIT gecommit (staat in .gitignore).
#
# Gebaseerd op: https://github.com/xibosignage/xibo-docker

# Database
MYSQL_DATABASE=xibo
MYSQL_USER=xibo
MYSQL_PASSWORD=vervang_met_sterk_wachtwoord
MYSQL_ROOT_PASSWORD=vervang_met_sterk_root_wachtwoord

# CMS instellingen
CMS_SERVER_NAME=signage.workinglocal.be
CMS_USE_HTTPS=true
XMR_HOST=xibo-cms

# Tijdzone
XTR_KEY=
